# Appwrite Configuration
# Renombra este archivo a .env y completa los valores
'
APPWRITE_ENDPOINT=http://localhost/v1
APPWRITE_PROJECT_ID=control-electoral
APPWRITE_DATABASE_ID=control_electoral_db

# Colecciones
APPWRITE_USUARIOS_COLLECTION_ID=usuarios
APPWRITE_RECINTOS_COLLECTION_ID=recintos
APPWRITE_MESAS_COLLECTION_ID=mesas
APPWRITE_ORGANIZACIONES_COLLECTION_ID=organizaciones_politicas
APPWRITE_ACTAS_COLLECTION_ID=actas
APPWRITE_VOTOS_COLLECTION_ID=votos_por_organizacion

# Storage
APPWRITE_BUCKET_ID=actas_fotos

# Aplicación
DEFAULT_PASSWORD=Cambiar123!
LAPLACIAN_THRESHOLD=100.0
MIN_SUFRAGANTES=0
MAX_SUFRAGANTES=500
'